# Copie este arquivo para .env e preencha os valores

# ── App ───────────────────────────────────────
PORT=3000
NODE_ENV=production
JWT_SECRET=troque_por_uma_chave_segura

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MONTHLY_BUDGET_USD=50

# ── OpenClaw Gateway ──────────────────────────
# URL do OpenClaw Gateway (dentro Docker: host.docker.internal)
OPENCLAW_URL=http://host.docker.internal:3000
OPENCLAW_TOKEN=123456

# ── Facebook / Instagram ──────────────────────
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── Webhooks Instagram ────────────────────────
WEBHOOK_VERIFY_TOKEN=pixel_obra_webhook_2024

# ── WhatsApp ──────────────────────────────────
# Número que recebe alertas do sistema
WHATSAPP_ALERT_NUMBER=+55XXXXXXXXXXX
# Número do dono (para notificações de leads)
OWNER_PHONE=5585999183883

# ── Email (Gmail SMTP) ───────────────────────
EMAIL_USER=
EMAIL_PASS=

# ── IMAP (Monitor de E-mails de Proposta) ────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# ── MySQL ─────────────────────────────────────
# Senhas usadas pelo docker-compose para criar o banco
MYSQL_ROOT_PASSWORD=root123
MYSQL_PASSWORD=pixelobra123
# DATABASE_URL é montado automaticamente pelo docker-compose
# DATABASE_URL=mysql://pixelobra:pixelobra123@localhost:3306/pixelobra

# ── VirusTotal (Segurança de Arquivos) ───────
VIRUSTOTAL_API_KEY=
